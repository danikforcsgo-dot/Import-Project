FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

COPY scanner.py .

RUN pip install --no-cache-dir \
    ccxt \
    pandas \
    numpy \
    ta \
    requests \
    psycopg2-binary \
    pytz

ENV PYTHONUNBUFFERED=1

CMD ["python", "scanner.py"]
